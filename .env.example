# ── crypto.com Exchange (grid trading bot) ─────────────────────────
CDX_API_KEY=your_cryptodotcom_api_key
CDX_API_SECRET=your_cryptodotcom_api_secret

# ── AI Optimiser (weekly grid parameter review) ─────────────────────
# Primary: Groq — free, no credit card, UK data centre
# Sign up: https://console.groq.com  → API Keys → Create
GROQ_API_KEY=your_groq_api_key

# Fallback: Cerebras — free, no credit card, activates if Groq fails
# Sign up: https://cloud.cerebras.ai → API Keys → Create
CEREBRAS_API_KEY=your_cerebras_api_key

# ── Telegram ────────────────────────────────────────────────────────
# BotFather → /newbot → copy the token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Your personal chat ID: message @userinfobot to find it
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── FX rate (used by grid bot) ──────────────────────────────────────
GBP_USD_RATE=1.27
